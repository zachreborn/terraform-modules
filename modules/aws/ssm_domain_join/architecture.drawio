              <mxPoint x="435" y="505" />
              <mxPoint x="435" y="397" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 4. IAM Role grants SSM Agent permission to read secret — exits TOP of IAM Role, enters BOTTOM of SSM Agent -->
        <mxCell id="46" value="4. Gives Agent permissions" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;fontSize=10;fontStyle=1;strokeColor=#880088;fontColor=#880088;strokeWidth=2;" edge="1" source="22" target="21" parent="1">
