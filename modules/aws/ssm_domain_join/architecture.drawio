        <mxCell id="41" value="2. delivers document" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontStyle=1;strokeColor=#0055aa;fontColor=#0055aa;strokeWidth=2;" edge="1" source="12" target="21" parent="1">
