              <mxPoint x="435" y="262" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 3. IAM policy attaches to IAM Role — exits RIGHT, bends up via x=435 gap -->
        <mxCell id="42" value="3. attaches inline policy" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;fontStyle=1;strokeColor=#880088;fontColor=#880088;strokeWidth=2;" edge="1" source="13" target="22" parent="1">
